# PostgreSQL — free tier: https://neon.tech or https://supabase.com (Project Settings → Database → URI)
# Must include ?sslmode=require for most cloud hosts
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Min. 16 characters; use a long random string in production (Vercel → Environment Variables)
SESSION_SECRET="replace-with-a-long-random-secret"

# התחברות עם Google (אופציונלי) — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Redirect URI חייב לכלול בדיוק: {כתובת ציבורית}/api/auth/google/callback — ללא סלאש בסוף, ללא פרמטרים (?)
# דוגמה פרודקשן: https://your-project.vercel.app/api/auth/google/callback
# דוגמה מקומית: http://localhost:3000/api/auth/google/callback
# ב-Vercel: הגדירו NEXT_PUBLIC_APP_URL לאותה כתובת כמו ב-Google Console (מומלץ)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# כתובת האתר לקישורי הזמנה במייל וב-OAuth (חשוב בפרודקשן — אותה כתובת כמו Authorized redirect URI ב-Google)
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# שליחת מיילי הזמנה (אופציונלי — בלי זה יוצג קישור להעתקה בממשק)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ניהול דברים <noreply@your-domain.com>"
