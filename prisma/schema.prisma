generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  topics       TopicUser[]
  tasks        TaskUser[]
  topicsCreated Topic[]     @relation("TopicCreator")
  tasksCreated  Task[]      @relation("TaskCreator")
  invitationsSent Invitation[] @relation("InvitedBy")
  expensesCreated TopicExpense[] @relation("ExpenseCreator")
}

model Invitation {
  id          String    @id @default(cuid())
  /// null = הזמנה גנרית (קישור אחד לכולם), אחרת מייל ספציפי
  email       String?
  token       String    @unique
  expiresAt   DateTime
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  @@index([email])
}

model Topic {
  id          String      @id @default(cuid())
  title       String
  /// Hex כמו #aabbcc; null = צבע אוטומטי ייחודי לפי id
  color       String?
  createdAt   DateTime    @default(now())
  createdById String?
  createdBy   User?       @relation("TopicCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks       Task[]
  users       TopicUser[]
  expenses    TopicExpense[]
  professionals TopicProfessional[]
  events      TopicEvent[]
  shoppingItems TopicShoppingItem[]
  packingItems TopicPackingItem[]
}

model TopicExpense {
  id          String   @id @default(cuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ILS")
  description String?
  spentAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([topicId, spentAt])
}

model TopicProfessional {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  phone     String
  notes     String?
  createdAt DateTime @default(now())

  @@index([topicId])
}

model TopicEvent {
  id        String    @id @default(cuid())
  topicId   String
  topic     Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title     String
  startsAt  DateTime
  endsAt    DateTime?
  allDay    Boolean   @default(false)
  location  String?
  createdAt DateTime  @default(now())

  @@index([topicId, startsAt])
}

model TopicShoppingItem {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([topicId])
}

model TopicPackingItem {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title     String
  packed    Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([topicId])
}

model TopicUser {
  topicId String
  userId  String
  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([topicId, userId])
}

model Task {
  id            String           @id @default(cuid())
  title         String
  description   String?
  done          Boolean          @default(false)
  doneAt        DateTime?
  topicId       String?
  topic         Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  scheduledAt   DateTime?
  dueAt         DateTime?
  createdAt     DateTime         @default(now())
  createdById   String?
  createdBy     User?            @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  users         TaskUser[]
  dependsOn     TaskDependency[] @relation("DependentTask")
  dependents    TaskDependency[] @relation("PrerequisiteTask")
}

model TaskUser {
  taskId String
  userId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

/// Task `taskId` depends on prerequisite `dependsOnTaskId` (must complete prerequisite first).
model TaskDependency {
  taskId          String
  dependsOnTaskId String
  task            Task @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn       Task @relation("PrerequisiteTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@id([taskId, dependsOnTaskId])
}
